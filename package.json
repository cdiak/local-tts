{
  "name": "obsidian-tts",
  "version": "0.1.0",
  "description": "Local neural text-to-speech for Obsidian using Kokoro-82M. Word-level highlighting, play/pause, and click-to-seek in your notes — a fully offline Eleven Reader experience.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs"
  },
  "keywords": [
    "obsidian",
    "tts",
    "text-to-speech",
    "kokoro",
    "local-ai",
    "offline",
    "highlight",
    "read-aloud"
  ],
  "author": "cdiak",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "0.25.2",
    "obsidian": "latest",
    "typescript": "5.5.4"
  },
  "dependencies": {
    "kokoro-js": "^1.2.1"
  }
}
